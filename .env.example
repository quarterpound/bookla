NODE_ENV=development

# Local Postgres — used by Prisma and the API
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bookla?schema=public

# Symmetric secret used to sign JWTs (dev only — use Secrets Manager in prod)
JWT_SECRET=replace-me-with-a-long-random-string

# CORS — comma-separated origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:5173

# SMS provider (console logs the OTP code to stdout; production swaps to Twilio/etc.)
SMS_PROVIDER=console

# Frontend
VITE_API_URL=http://localhost:4200
